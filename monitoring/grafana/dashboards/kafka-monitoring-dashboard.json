{
  "uid": "kafka-monitoring",
  "title": "Kafka Monitoring",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "type": "timeseries",
      "title": "Kafka brokers",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "kafka_brokers",
          "legendFormat": "brokers"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Kafka topics partitions",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "kafka_topic_partitions",
          "legendFormat": "{{topic}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Kafka consumer group lag",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "kafka_consumergroup_lag",
          "legendFormat": "{{consumergroup}} / {{topic}}"
        }
      ]
    }
  ]
}
