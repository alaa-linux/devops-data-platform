{
  "uid": "platform-global",
  "title": "Platform Global Monitoring",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "type": "stat",
      "title": "Kafka brokers",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "kafka_brokers"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Spark alive workers",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "spark_master_alive_workers"
        }
      ]
    },
    {
      "type": "stat",
      "title": "PostgreSQL connections",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "pg_stat_activity_count"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Airflow running tasks",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "airflow_executor_running_tasks"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "CPU usage containers",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(container_cpu_usage_seconds_total[1m])",
          "legendFormat": "{{name}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Memory usage containers",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "container_memory_usage_bytes",
          "legendFormat": "{{name}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Node CPU load",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "node_load1",
          "legendFormat": "load1"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Node memory available",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "node_memory_MemAvailable_bytes",
          "legendFormat": "available memory"
        }
      ]
    }
  ]
}
